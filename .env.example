# Networking
CADDY_HTTP_PORT=8000
LEMONADE_UPSTREAM=127.0.0.1:13305
LITELLM_UPSTREAM=127.0.0.1:4000

# Container images
CADDY_IMAGE=caddy:2.8-alpine
LITELLM_IMAGE=docker.litellm.ai/berriai/litellm:main-stable

# LiteLLM auth
LITELLM_MASTER_KEY=sk-change-me

# Existing Lemonade server (detected on the host)
LEMONADE_API_BASE=http://127.0.0.1:13305/v1
LEMONADE_API_KEY=none

# Local FLM NPU server
PHI4_NPU_API_BASE=http://127.0.0.1:52625/v1
PHI4_NPU_API_KEY=none

# Optional local Ollama passthrough
OLLAMA_API_BASE=http://127.0.0.1:11434/v1
OLLAMA_API_KEY=ollama
